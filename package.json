{
  "name": "elegant-star-invitations",
  "version": "1.0.0",
  "description": "Premium invitation atelier website for Elegant Star.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke-check.mjs",
    "test": "npm run typecheck && npm run lint && npm run smoke",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
